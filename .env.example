###############################################################
# Variables de entorno (ejemplo)
# -------------------------------------------------------------
# Si quieres usar .env con docker compose, crea un archivo ".env"
# copiando este ".env.example" y completándolo.
###############################################################

# Puerto del servidor dentro del contenedor
PORT=3000

# SQLite (ruta dentro del contenedor)
DB_PATH=/app/data/barberia.db

# Zona horaria de referencia
ZONA_HORARIA=America/Argentina/Buenos_Aires

# Configuración de negocio
DURACION_TURNO_MINUTOS=60
HORAS_MINIMAS_CANCELACION=1
MENSAJE_PAGO_EFECTIVO=El pago del servicio se realiza únicamente en efectivo y de forma presencial en la barbería.

# Seguridad JWT (CAMBIAR EN PRODUCCIÓN)
JWT_SECRET=pon_aqui_una_clave_larga_y_segura
JWT_EXPIRATION=7d

